<?xml version="1.0" encoding="UTF-8"?>
<!--
  deploy.xml – Apache ODE BPEL Deployment Descriptor
  Q8: BPEL deployment configuration for Apache ODE engine.

  Maps partner links to concrete WSDL service endpoints.
  Deploy this XML together with PlaceOrder.bpel and PlaceOrder.wsdl
  as a ZIP archive into %CATALINA_HOME%/webapps/ode/processes/
-->
<deploy xmlns="http://www.apache.org/ode/schemas/dd/2007/03"
        xmlns:tns="http://globalbooks.com/bpel/v1/placeorder"
        xmlns:cat="http://catalog.globalbooks.com/v1"
        xmlns:ord="http://orders.globalbooks.com/v1">

    <process name="tns:PlaceOrderProcess">
        <active>true</active>
        <retired>false</retired>
        <process-events generate="all"/>

        <!-- Partner link bindings: links process roles to concrete endpoints -->
        <provide partnerLink="client">
            <service name="tns:PlaceOrderService"
                     port="PlaceOrderPort"/>
        </provide>

        <invoke partnerLink="catalogPartner">
            <service name="cat:CatalogService"
                     port="CatalogPort"/>
        </invoke>

        <invoke partnerLink="ordersPartner">
            <service name="ord:OrdersService"
                     port="OrdersPort"/>
        </invoke>
    </process>

</deploy>
