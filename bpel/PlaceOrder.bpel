<?xml version="1.0" encoding="UTF-8"?>
<!--
  PlaceOrder BPEL 2.0 Process Definition
  GlobalBooks Inc. – Order Orchestration
  Q8: BPEL orchestration process

  Flow:
  1. Receive PlaceOrderRequest from client
  2. ForEach item → Invoke CatalogService.getBookPrice() [LOOP]
  3. Invoke OrdersService to create the order
  4. Reply PlaceOrderResponse to client
-->
<process name="PlaceOrderProcess"
         targetNamespace="http://globalbooks.com/bpel/v1/placeorder"
         xmlns="http://docs.oasis-open.org/wsbpel/2.0/process/executable"
         xmlns:tns="http://globalbooks.com/bpel/v1/placeorder"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema"
         xmlns:cat="http://catalog.globalbooks.com/v1"
         xmlns:ord="http://orders.globalbooks.com/v1"
         queryLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xpath1.0"
         expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xpath1.0">

    <!-- ================================================================= -->
    <!-- Partner Links                                                        -->
    <!-- ================================================================= -->
    <partnerLinks>
        <!-- Client calling this BPEL process -->
        <partnerLink name="client"
                     partnerLinkType="tns:PlaceOrderLinkType"
                     myRole="PlaceOrderProvider"/>

        <!-- CatalogService – SOAP partner -->
        <partnerLink name="catalogPartner"
                     partnerLinkType="tns:CatalogLinkType"
                     partnerRole="CatalogProvider"/>

        <!-- OrdersService – REST partner (bridged via SOAP adapter in ODE) -->
        <partnerLink name="ordersPartner"
                     partnerLinkType="tns:OrdersLinkType"
                     partnerRole="OrdersProvider"/>
    </partnerLinks>

    <!-- ================================================================= -->
    <!-- Variables                                                            -->
    <!-- ================================================================= -->
    <variables>
        <variable name="placeOrderRequest"
                  messageType="tns:PlaceOrderRequestMessage"/>
        <variable name="placeOrderResponse"
                  messageType="tns:PlaceOrderResponseMessage"/>

        <!-- Price lookup in/out for CatalogService -->
        <variable name="priceRequest"
                  messageType="cat:GetBookPriceRequestMessage"/>
        <variable name="priceResponse"
                  messageType="cat:GetBookPriceResponseMessage"/>

        <!-- Order creation in/out for OrdersService -->
        <variable name="createOrderRequest"
                  messageType="ord:CreateOrderRequestMessage"/>
        <variable name="createOrderResponse"
                  messageType="ord:CreateOrderResponseMessage"/>

        <!-- Running total amount accumulator -->
        <variable name="totalAmount" type="xsd:decimal"/>
        <!-- Loop counter item index -->
        <variable name="itemCount"   type="xsd:integer"/>
    </variables>

    <!-- ================================================================= -->
    <!-- Fault Handlers                                                       -->
    <!-- ================================================================= -->
    <faultHandlers>
        <catch faultName="cat:BookNotFoundFault">
            <reply partnerLink="client"
                   portType="tns:PlaceOrderPortType"
                   operation="placeOrder"
                   variable="placeOrderResponse"
                   faultName="tns:PlaceOrderFault"/>
        </catch>
        <catchAll>
            <reply partnerLink="client"
                   portType="tns:PlaceOrderPortType"
                   operation="placeOrder"
                   variable="placeOrderResponse"
                   faultName="tns:PlaceOrderFault"/>
        </catchAll>
    </faultHandlers>

    <!-- ================================================================= -->
    <!-- Main Process Sequence                                                -->
    <!-- ================================================================= -->
    <sequence>

        <!-- ── Step 1: Receive PlaceOrder request from client ──────────── -->
        <receive partnerLink="client"
                 portType="tns:PlaceOrderPortType"
                 operation="placeOrder"
                 variable="placeOrderRequest"
                 createInstance="yes"/>

        <!-- ── Step 2: Initialize total amount ──────────────────────────── -->
        <assign>
            <copy>
                <from>0</from>
                <to variable="totalAmount"/>
            </copy>
            <copy>
                <from>count($placeOrderRequest.parameters/items/item)</from>
                <to variable="itemCount"/>
            </copy>
        </assign>

        <!-- ── Step 3: LOOP – Get price for each item from CatalogService ── -->
        <!--
            Q8: Loop for price lookup
            ForEach iterates over each item in the order.
            For each item, invokes CatalogService.getBookPrice() via SOAP.
            The BPEL engine manages the loop state.
        -->
        <forEach counterName="itemIndex" parallel="no">
            <startCounterValue>1</startCounterValue>
            <finalCounterValue>$itemCount</finalCounterValue>
            <scope>
                <sequence>

                    <!-- Prepare getBookPrice request -->
                    <assign>
                        <copy>
                            <from>$placeOrderRequest.parameters/items/item[$itemIndex]/bookId</from>
                            <to variable="priceRequest" part="parameters"
                                query="/getBookPriceRequest/bookId"/>
                        </copy>
                    </assign>

                    <!-- Invoke CatalogService.getBookPrice() via SOAP -->
                    <invoke partnerLink="catalogPartner"
                            portType="cat:CatalogPortType"
                            operation="getBookPrice"
                            inputVariable="priceRequest"
                            outputVariable="priceResponse"/>

                    <!-- Accumulate: totalAmount += price * quantity -->
                    <assign>
                        <copy>
                            <from>$totalAmount
                                + ($priceResponse.parameters/priceResponse/price
                                   * $placeOrderRequest.parameters/items/item[$itemIndex]/quantity)
                            </from>
                            <to variable="totalAmount"/>
                        </copy>
                        <!-- Store unit price back into request for OrdersService -->
                        <copy>
                            <from>$priceResponse.parameters/priceResponse/price</from>
                            <to>$placeOrderRequest.parameters/items/item[$itemIndex]/unitPrice</to>
                        </copy>
                    </assign>

                </sequence>
            </scope>
        </forEach>

        <!-- ── Step 4: Invoke OrdersService to create the order ─────────── -->
        <assign>
            <copy>
                <from>$placeOrderRequest.parameters</from>
                <to variable="createOrderRequest" part="parameters"/>
            </copy>
            <copy>
                <from>$totalAmount</from>
                <to variable="createOrderRequest" part="parameters"
                    query="/createOrderRequest/totalAmount"/>
            </copy>
        </assign>

        <invoke partnerLink="ordersPartner"
                portType="ord:OrdersPortType"
                operation="createOrder"
                inputVariable="createOrderRequest"
                outputVariable="createOrderResponse"/>

        <!-- ── Step 5: Build and send response to client ─────────────────── -->
        <assign>
            <copy>
                <from>$createOrderResponse.parameters/orderId</from>
                <to variable="placeOrderResponse" part="parameters"
                    query="/placeOrderResponse/orderId"/>
            </copy>
            <copy>
                <from>$totalAmount</from>
                <to variable="placeOrderResponse" part="parameters"
                    query="/placeOrderResponse/totalAmount"/>
            </copy>
            <copy>
                <from>'PENDING'</from>
                <to variable="placeOrderResponse" part="parameters"
                    query="/placeOrderResponse/status"/>
            </copy>
        </assign>

        <!-- Q8: Reply Activity -->
        <reply partnerLink="client"
               portType="tns:PlaceOrderPortType"
               operation="placeOrder"
               variable="placeOrderResponse"/>

    </sequence>
</process>
