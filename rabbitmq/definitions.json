      "durable":     true,
      "auto_delete": false,
      "internal":    false,
      "arguments":   {}
    }
  ],
  "queues": [
    {
      "name":        "payments.queue",
      "vhost":       "/",
      "durable":     true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange":    "dlx.exchange",
        "x-dead-letter-routing-key": "payments.dlq",
        "x-message-ttl":             30000
      }
    },
    {
      "name":        "shipping.queue",
      "vhost":       "/",
      "durable":     true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange":    "dlx.exchange",
        "x-dead-letter-routing-key": "shipping.dlq",
        "x-message-ttl":             30000
      }
    },
    {
      "name":        "payments.dlq",
